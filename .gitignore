# =============================================================================
#  Antigravity Corp — .gitignore
# =============================================================================

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ---- Virtual environments ----
venv/
.venv/
env/
ENV/

# ---- IDE / Editor ----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---- Raw CSV data (regenerated by generate_data.py) ----
users.csv
products.csv
orders.csv

# ---- Cleaned CSVs are INCLUDED (needed for Streamlit Cloud deployment) ----
# cleaned_users.csv      <- tracked
# cleaned_products.csv   <- tracked
# cleaned_orders.csv     <- tracked

# ---- Environment / Secrets ----
.env
.env.local
*.key
